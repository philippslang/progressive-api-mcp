# OpenAPI MCP Server configuration
# Override precedence: CLI flags > environment variables > this file > defaults

server:
  host: "127.0.0.1"          # PROGRAPIMCP_SERVER_HOST / --host
  port: 8080                  # PROGRAPIMCP_SERVER_PORT / --port
  transport: "http"           # PROGRAPIMCP_SERVER_TRANSPORT / --transport
                              # Options: "http" (Streamable HTTP) or "stdio"
  # tool_prefix: "myapi"     # PROGRAPIMCP_SERVER_TOOL_PREFIX / --tool-prefix
                              # Optional. Prepends "myapi_" to all tool names (e.g. myapi_http_get).
                              # Omit or leave empty for original names. Must start with a letter
                              # or underscore; only letters, digits, underscores allowed.

apis:
  - name: petstore                           # Unique identifier used in tool calls
    definition: "./petstore.yaml"            # Path to OpenAPI 3.x file (YAML or JSON)
    host: "https://api.example.com"          # Optional: overrides servers[0].url host
    base_path: "/v2"                         # Optional: overrides servers[0].url path
    # allow_list:                            # Optional. Omit entirely for full access.
    #   tools:                               # Only these tool names are registered.
    #     - explore_api                      # Valid values: explore_api, get_schema,
    #     - get_schema                       #   http_get, http_post, http_put, http_patch
    #     - http_get                         # Omit for all tools (default).
    #   paths:                               # Per-tool path restrictions (OpenAPI templates).
    #     http_get:                          # Omit a tool for all-paths-allowed.
    #       - /pets                          # Exact template match, e.g. /pets/{id} not /pets/42
    #       - /pets/{id}

    # ignore_headers:                        # Optional. Header names to suppress (case-insensitive).
    #   - Authorization                      # Ignored headers are hidden from get_schema output
    #   - X-Internal-Token                   # and not required during request validation.

  # - name: another-api
  #   definition: "./another.yaml"
